# Postgres connection string (Neon, Supabase, local Postgres, etc.)
# - Dev local : utilise une connexion directe (pas de pooler)
# - Prod (Vercel + Neon) : utilise la connexion poolée pgBouncer
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# DIRECT_URL : connexion directe (sans pooler). Requise par Prisma migrate.
# - En local : mettre la même valeur que DATABASE_URL
# - En prod (Neon) : utiliser l'URL "direct connection" du dashboard Neon
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Better Auth — REQUIRED. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="<openssl rand -base64 32>"
BETTER_AUTH_URL="http://localhost:3000"
# Comma-separated list of trusted origins (production domains, preview URLs)
BETTER_AUTH_TRUSTED_ORIGINS=""
# Public base URL used by the browser auth client (defaults to BETTER_AUTH_URL)
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Logging level: "error" | "warn" | "query"
DATABASE_LOG_LEVEL="error"

# Bootstrap admin/member accounts (optional, used by scripts/setup-local-auth.ts)
DOCBEL_ADMIN_EMAIL=""
DOCBEL_ADMIN_PASSWORD=""
DOCBEL_MEMBER_EMAIL=""
DOCBEL_MEMBER_PASSWORD=""

# Document generator — email transactionnel (Resend) pour l'envoi des PDF/DOCX générés
# Créer un compte sur https://resend.com et générer une clé API
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@docbel.be"

# Notification admin à chaque génération de document (facultatif).
# Si défini ET RESEND_API_KEY défini, l'admin reçoit un email à chaque génération.
ADMIN_NOTIFICATION_EMAIL=""

# Secret partagé pour les routes CRON Vercel (purge documents + sync inbox).
# Sur Vercel, défini automatiquement en production via le dashboard Cron.
# Générer en local avec : openssl rand -hex 32
CRON_SECRET=""
# Legacy : utilisé en fallback si CRON_SECRET n'est pas défini (purge documents uniquement)
CRON_PURGE_SECRET=""

# Contact inbox — envoi via Resend depuis contact@docbel.be
# Le domaine docbel.be doit être vérifié dans Resend (DNS DKIM/SPF).
CONTACT_EMAIL_FROM="contact@docbel.be"

# Contact inbox — réception via IMAP OVH (pro3.mail.ovh.net pour les comptes Pro Mail)
# Idéalement utiliser un mot de passe applicatif OVH plutôt que le mdp principal.
CONTACT_IMAP_HOST="pro3.mail.ovh.net"
CONTACT_IMAP_PORT="993"
CONTACT_IMAP_USER="contact@docbel.be"
CONTACT_IMAP_PASSWORD=""

# OAuth Google pour les partenaires (FACULTATIF).
# Si configuré, les partenaires peuvent se connecter en un clic via leur compte Google
# professionnel. Le domaine de leur email Google doit être dans la liste blanche
# (table PartnerDomain). Sans whitelist, l'inscription via Google est refusée.
#
# Pour l'activer :
# 1) Créer un projet sur https://console.cloud.google.com → APIs & Services → Credentials
# 2) Créer un OAuth client ID (type "Web application")
# 3) Autoriser le redirect URI : http://localhost:3000/api/auth/callback/google
#    (et l'équivalent en prod : https://docbel.be/api/auth/callback/google)
# 4) Copier les identifiants ici, et mettre NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=""

# ============================================================
# Chat IA chômage + RAG (recherche augmentée)
# ============================================================
# Clé Anthropic pour le chat IA chômage (modèle Claude).
ANTHROPIC_API_KEY=
# Clé OpenAI : fallback embeddings RAG + transcription voix (Whisper).
OPENAI_API_KEY=
# Clé Voyage AI : embeddings RAG (fournisseur prioritaire).
VOYAGE_API_KEY=
# Clé Brave Search : recherche web pour l'IA.
BRAVE_SEARCH_API_KEY=

# ============================================================
# Stockage de fichiers
# ============================================================
# Token Vercel Blob : upload et stockage des fichiers.
BLOB_READ_WRITE_TOKEN=
# Quota de stockage par utilisateur (en octets).
MAX_USER_STORAGE_BYTES=

# ============================================================
# Génération d'image à la une (OpenAI Images)
# ============================================================
# Clé OpenAI utilisée pour générer les bannières d'article (réutilise OPENAI_API_KEY
# ci-dessus si déjà défini). Jamais exposée au client : les appels passent par
# /api/admin/news/[newsId]/featured-image/generate (admin uniquement).
OPENAI_API_KEY=
# Modèle d'image OpenAI (défaut : gpt-image-2).
OPENAI_IMAGE_MODEL=gpt-image-2

# ============================================================
# PDF Forms (nouvelle fonctionnalité — admin/pdf)
# ============================================================
# Police Unicode optionnelle pour la génération (caractères hors Latin-1).
# Déposer le fichier dans public/fonts/NotoSans-Regular.ttf (non versionné).
# Sans police : repli automatique sur Helvetica (peut afficher "?" pour
# certains caractères étrangers).

# Stockage des PDF sources : Vercel Blob si défini, sinon disque local privé.
# (BLOB_READ_WRITE_TOKEN est déjà utilisé par l'ancien système le cas échéant.)

# --- itsme (prefill OIDC) — FACULTATIF, accès partenaire requis ---
ITSME_CLIENT_ID=""
ITSME_CLIENT_SECRET=""
ITSME_REDIRECT_URI=""
ITSME_ISSUER=""
ITSME_SCOPES="openid profile email"

# --- Doccle (envoi sécurisé de documents) — FACULTATIF, accès partenaire requis ---
DOCCLE_API_BASE_URL=""
DOCCLE_API_KEY=""
DOCCLE_SENDER_ID=""

# ============================================================
# Tests E2E Playwright (FACULTATIF — uniquement pour `pnpm test:e2e`)
# ============================================================
# Compte admin utilisé pour les tests E2E. DOIT exister en DB et avoir role=admin.
# Sans ces vars, les specs e2e sont skipped automatiquement.
# Voir tests/e2e/README.md pour les pré-requis (seed-demo-accounts, dev server, …).
E2E_ADMIN_EMAIL=""
E2E_ADMIN_PASSWORD=""

# ============================================================
# Sécurité — secrets dérivés (utilisés dans le code)
# ============================================================
# NRN belge (booking) : HMAC + AES. CRITIQUE — sans cette clé, repli sur un secret
# de fallback connu (à supprimer, cf. SECURITY_QUEUE S1). Générer : openssl rand -hex 32
BOOKING_NRN_SECRET=""
# Codes de reprise de dossier (hash). Générer : openssl rand -hex 32
RESUME_CODE_SECRET=""

# ============================================================
# Paiement (Stripe) — checkout
# ============================================================
STRIPE_SECRET_KEY=""

# ============================================================
# KBO / BCE — open data entreprises (import)
# ============================================================
KBO_OPEN_DATA_URL=""
KBO_OPEN_DATA_USER=""
KBO_OPEN_DATA_PASSWORD=""

# ============================================================
# Fournisseurs configurables (laisser vide = défaut / désactivé)
# ============================================================
# Provider de vérification nom↔IBAN (selon intégration choisie).
IBAN_NAME_PROVIDER=""
# Provider IA pour la boussole d'orientation / les formations (fallback local si vide).
ORIENTATION_AI_PROVIDER=""
TRAINING_AI_PROVIDER=""
# Provider de paiement pour les formations.
TRAINING_PAYMENT_PROVIDER=""
# Active le runtime des arbres de décision (Decision Builder). "true" pour activer.
DECISION_TREE_RUNTIME_ENABLED=""
# Mot de passe des comptes démo (seed) — NE PAS réutiliser un vrai mot de passe.
DEMO_ACCOUNTS_PASSWORD=""
# Unsplash : images d'illustration (facultatif).
UNSPLASH_ACCESS_KEY=""

# ============================================================
# Filet de sécurité PDF Forms
# ============================================================
# Filet de sécurité : "1" bascule tous les formulaires PDF vers l'ancien
# rendu (grille dense) sans redéploiement. Absent/tout autre valeur = nouveau
# rendu compact (défaut).
PDF_FORM_LEGACY_LAYOUT=

# ============================================================
# URLs publiques de l'app (selon l'environnement)
# ============================================================
# Utilisées pour construire des liens absolus (emails, canonical, etc.).
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ============================================================
# Carte du localisateur de bureaux (/outils/bureaux)
# ============================================================
# Carte à tuiles du localisateur de bureaux (/outils/bureaux). VIDE = carte SVG de secours.
# Template de tuiles raster Leaflet, ex. un serveur MapTiler/Stadia/self-hosted conforme à un usage production
# (NE PAS pointer un serveur public gratuit interdit en prod). Ex de format : https://.../{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_TILE_URL=
