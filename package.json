{
  "name": "docbel-nextjs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e .env.local -- prisma migrate dev",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:setup": "dotenv -e .env.local -- prisma db push && pnpm seed && tsx scripts/setup-local-auth.ts",
    "auth:backfill": "tsx scripts/backfill-better-auth-accounts.ts",
    "seed:canonical": "dotenv -e .env.local -- tsx scripts/seed-canonical-fields.ts",
    "seed:lookup": "dotenv -e .env.local -- tsx scripts/seed-lookup-onem.ts",
    "lookup:import": "dotenv -e .env.local -- tsx scripts/import-lookup-bulk.ts",
    "lookup:setup-trgm": "dotenv -e .env.local -- tsx scripts/setup-lookup-trgm.ts",
    "lookup:import-streets": "dotenv -e .env.local -- tsx scripts/import-bestaddress-streets.ts",
    "bureaux:sync-onem": "dotenv -e .env.local -- tsx scripts/bureaux-sync-onem.ts",
    "bureaux:sync-sections-paiement": "dotenv -e .env.local -- tsx scripts/bureaux-sync-sections-paiement.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "canvas",
      "core-js",
      "esbuild",
      "msw",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.10.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/core": "^2.6.6",
    "@tiptap/extension-image": "^2.6.6",
    "@tiptap/extension-link": "^2.6.6",
    "@tiptap/extension-placeholder": "^2.6.6",
    "@tiptap/extension-table": "^2.6.6",
    "@tiptap/extension-table-cell": "^2.6.6",
    "@tiptap/extension-table-header": "^2.6.6",
    "@tiptap/extension-table-row": "^2.6.6",
    "@tiptap/pm": "^2.6.6",
    "@tiptap/react": "^2.6.6",
    "@tiptap/starter-kit": "^2.6.6",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "docxtemplater": "^3.68.6",
    "dompurify": "^3.4.2",
    "flag-icons": "^7.5.0",
    "imapflow": "^1.3.3",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.11.0",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.9",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.0.379",
    "pixelmatch": "^7.2.0",
    "pizzip": "^3.2.0",
    "pngjs": "^7.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "react-pdf": "^9.1.0",
    "react-rnd": "^10.5.3",
    "recharts": "3.8.0",
    "resend": "^4.8.0",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^4.4.0"
