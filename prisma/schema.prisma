// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  user
  partner
  moderator
  admin
}

enum UserStatus {
  active
  pending
  disabled
  locked
}

enum OrganismeType {
  federal // ONEM, ONP, BCSS, INASTI
  regional // Forem, Actiris, VDAB, ADG
  local // Commune, CPAS
  social // Mutuelle, Caisse de chômage (CAPAC, CSC, CGSLB, FGTB)
  professional // Secrétariat social, fiduciaire
  other
}

model User {
  id                  String     @id @default(cuid())
  name                String
  email               String     @unique
  emailVerified       Boolean    @default(false)
  image               String?
  password            String     @default("")
  role                UserRole   @default(user)
  status              UserStatus @default(active)
  emailVerifiedAt     DateTime?
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime   @default(now())
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  partnerOrganization String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  sessions            Session[]
  accounts            Account[]

  @@index([role])
  @@index([status])
  @@index([partnerOrganization])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model Page {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  content   Json      @default("[]")
  status    String    @default("draft")
  metaTitle String?
  metaDesc  String?
  ogImage   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  revisions PageRevision[]

  @@index([status])
  @@index([deletedAt])
  @@index([status, slug])
}

model PageRevision {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title     String
  content   Json     @default("[]")
  metaTitle String?
  metaDesc  String?
  ogImage   String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([pageId])
  @@index([createdAt])
}

model Activity {
  id           String   @id @default(cuid())
  user         String
  action       String // created, updated, deleted, published, unpublished, error
  resource     String // page, user, comment, setting
  resourceName String
  resourceId   String?
  details      String?
  createdAt    DateTime @default(now())
}

model File {
  id        String      @id @default(cuid())
  name      String
  type      String // "file" or "folder"
  fileType  String? // pdf, docx, xlsx, jpg, etc
  mimeType  String?
  size      Int? // bytes
  sha256    String?
  parentId  String?
  parent    File?       @relation("FileHierarchy", fields: [parentId], references: [id])
  children  File[]      @relation("FileHierarchy")
  isPrivate Boolean     @default(false)
  filePath  String? // relative path on disk
  createdBy String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  usage     FileUsage[]

  docTemplateSources  DocumentTemplate[]  @relation("DocTemplateSource")
  docGeneratedOutputs GeneratedDocument[] @relation("DocGeneratedOutput")

  @@index([parentId])
  @@index([parentId, type])
  @@index([type])
  @@index([isPrivate])
  @@index([createdBy])
  @@index([sha256])
}

model FileUsage {
  id        String   @id @default(cuid())
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  pageId    String?
  pageSlug  String // slug de la page qui utilise le fichier
  context   String? // description du lieu d'utilisation
  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([pageId])
  @@index([pageSlug])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#7C3AED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ToolSection {
  id          String   @id @default(cuid())
  name        String   @unique // "Chômage", "Emploi", etc.
  description String?
  order       Int      @default(0)
  icon        String?
  tools       Tool[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tool {
  id          String      @id @default(cuid())
  sectionId   String
  section     ToolSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  name        String
  slug        String      @unique // "preavis", "agr", etc.
  description String
  type        String // "calc_preavis", "calc_agr", "locator", "doc_generator", etc.
  icon        String?
  popular     Boolean     @default(false)
  timeMin     Int?
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  documentTemplate DocumentTemplate?

  @@index([sectionId])
  @@index([slug])
}

model News {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @default("")
  excerpt     String
  category    String
  color       String    @default("#7C3AED")
  emoji       String    @default("📰")
  status      String    @default("draft")
  featured    Boolean   @default(false)
  image       String?
  readingTime Int?
  views       Int       @default(0)
  publishedAt DateTime?
  scheduledAt DateTime?
  createdBy   String
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishedAt])
  @@index([status, publishedAt(sort: Desc)])
  @@index([status, category])
  @@index([featured, status])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("active") // active, unsubscribed
  source    String   @default("actualites")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InboxEmail {
  id             String   @id @default(cuid())
  // Folder = logical inbox category. Mirrors IMAP folders detected via SPECIAL-USE.
  // Values: "INBOX" | "SENT" | "SPAM" | "ARCHIVE" | "TRASH"
  folder         String   @default("INBOX")
  uid            Int
  uidValidity    String?
  // Headers
  messageId      String?
  inReplyTo      String?
  fromAddress    String
  fromName       String?
  replyToAddress String?
  replyToName    String?
  toAddresses    String   @default("") // JSON array of addresses
  ccAddresses    String   @default("") // JSON array of addresses
  subject        String   @default("")
  // Body (parsed)
  textBody       String   @default("")
  htmlBody       String?
  // Attachments metadata (we don't store file contents — just a list)
  attachments    Json     @default("[]") // [{filename, contentType, size}]
  // Status — mirrored from IMAP \Seen and \Flagged flags (server is authoritative)
  isRead         Boolean  @default(false)
  isFlagged      Boolean  @default(false)
  // Timestamps
  receivedAt     DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([folder, uid])
  @@index([folder, receivedAt(sort: Desc)])
  @@index([isRead])
  @@index([fromAddress])
  @@index([messageId])
  @@index([inReplyTo])
}

model BaremeFile {
  id             String   @id @default(cuid())
  name           String
  filePath       String
  effectiveDate  String
  uploadedAt     DateTime @default(now())
  description    String?
  fileType       String   @default("onem-rates")
  multiplicateur Float?
  status         String   @default("active")

  sheets    BareSheet[]
  createdBy String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([effectiveDate])
  @@index([status])
  @@index([fileType])
}

model BareSheet {
  id     String     @id @default(cuid())
  fileId String
  file   BaremeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String
  rowCount    Int
  colCount    Int     @default(0)

  // Données de la grille en JSON: [[cell1, cell2, ...], [cell1, ...], ...]
  cellData   String @default("[]")
  // Texte concaténé pour recherche full-text
  searchText String @default("")
  // Position dans le workbook
  sheetIndex Int    @default(0)

  createdAt DateTime @default(now())

  @@unique([fileId, name])
  @@index([fileId])
  @@index([category])
}

model DocumentTemplate {
  id                String  @id @default(cuid())
  toolId            String  @unique
  tool              Tool    @relation(fields: [toolId], references: [id], onDelete: Cascade)
  sourceFileId      String
  sourceFile        File    @relation("DocTemplateSource", fields: [sourceFileId], references: [id])
  sourceType        String // "pdf_acroform" | "pdf_flat" | "docx"
  schema            Json // DocumentField[] — voir lib/documents/types.ts
  outputFilenameTpl String  @default("document-{{date}}.pdf")
  rgpdNotice        String?
  retentionDays     Int     @default(30)
  status            String  @default("draft") // draft | published | archived
  version           Int     @default(1)

  // Organisme émetteur (ONEM, CPAS, etc.)
  organismeId String?
  organisme   Organisme? @relation(fields: [organismeId], references: [id])

  // Validité officielle du document
  effectiveDate DateTime? // Date à partir de laquelle ce document officiel est en vigueur
  expiresAt     DateTime? // Date connue de fin de validité (null = pas de date connue)
  officialRef   String? // Référence officielle ("Formulaire C1", "Annexe 4-bis", etc.)

  // Signature électronique
  requiresSignature Boolean @default(false)
  signaturePosition Json? // { page, x, y, w, h } — position de la signature sur le PDF

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generated   GeneratedDocument[]
  drafts      DocumentDraft[]
  revisions   DocumentTemplateRevision[]
  bundleItems     DocumentBundleItem[]
  analyticsEvents FormAnalyticsEvent[]

  @@index([status])
  @@index([organismeId])
  @@index([effectiveDate])
  @@index([expiresAt])
}

model DocumentTemplateRevision {
  id                String           @id @default(cuid())
  templateId        String
  template          DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version           Int
  schema            Json
  sourceType        String
  rgpdNotice        String?
  retentionDays     Int
  outputFilenameTpl String

  // Notes de changement entre versions
  changeNotes String? // Description libre des changements
  changeType  String  @default("minor") // minor | major | hotfix | source_update (= nouveau PDF officiel)
  diffSummary Json? // { added: [], removed: [], modified: [] } — calculé à la création

  createdBy String?
  createdAt DateTime @default(now())

  @@index([templateId])
  @@index([createdAt])
  @@index([changeType])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model GeneratedDocument {
  id           String           @id @default(cuid())
  templateId   String
  template     DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId       String?
  outputFileId String?
  outputFile   File?            @relation("DocGeneratedOutput", fields: [outputFileId], references: [id])
  payloadHash  String
  emailSentTo  String?
  ipHash       String?
  bundleRunId  String? // si généré dans le cadre d'un bundle
  createdAt    DateTime         @default(now())
  expiresAt    DateTime

  signature SignatureRecord?

  @@index([templateId])
  @@index([expiresAt])
  @@index([userId])
  @@index([bundleRunId])
}

model DocumentDraft {
  id         String           @id @default(cuid())
  templateId String
  template   DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId     String
  payload    Json
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([templateId, userId])
  @@index([userId])
}

model CommissionParitaire {
  id             String   @id @default(cuid())
  code           String   @unique
  numero         String
  numeroOfficiel String
  codeOfficiel5  String
  suffixeInterne String
  type           String
  nom            String
  label          String
  searchText     String
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([type])
  @@index([numeroOfficiel])
  @@index([code])
}

model PartnerDomain {
  id               String   @id @default(cuid())
  domain           String   @unique // ex: "cpas.brussels" (sans le @)
  organizationName String
  notes            String?
  isTest           Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
}

model U1Institution {
  id            String   @id @default(cuid())
  country       String   @unique
  countryCode   String?
  organization  String
  department    String?
  alternateName String?
  addressLines  Json     @default("[]")
  postalAddress String?
  phone         String?
  fax           String?
  website       String?
  emails        Json     @default("[]")
  extra         Json?
  updatedBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([country])
}

// =====================================================================
// Documents — extension organismes / presets / signatures / bundles
// =====================================================================

/// Organisme émetteur d'un document (ONEM, CPAS, mutuelle, etc.).
/// Utilisé pour grouper et filtrer les modèles dans l'admin.
model Organisme {
  id          String        @id @default(cuid())
  code        String        @unique // "onem", "cpas", "capac", "csc", etc.
  name        String // "Office National de l'Emploi"
  shortName   String? // "ONEM"
  type        OrganismeType @default(other)
  color       String        @default("#7C3AED")
  logoUrl     String?
  website     String?
  description String?
  active      Boolean       @default(true)
  order       Int           @default(0)
  createdBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  templates DocumentTemplate[]

  @@index([type])
  @@index([active])
  @@index([order])
}

/// Preset de validation réutilisable pour les champs de formulaire.
/// Permet de définir une fois "Nom de famille" et de l'appliquer à tous les docs.
/// Les presets builtin sont seedés et non supprimables.
model FieldValidationPreset {
  id          String  @id @default(cuid())
  name        String  @unique // "Nom de famille", "Date passée", "Salaire mensuel"
  description String?
  category    String  @default("custom") // identity | contact | financial | date | belgian | custom
  fieldType   String // text | textarea | number | date | select | checkbox | etc.

  // Validation rules (toutes optionnelles, combinées en AND)
  regex      String?
  regexFlags String? // ex: "i" pour case insensitive
  minLength  Int?
  maxLength  Int?
  minValue   Float? // pour number
  maxValue   Float?
  minDate    String? // "today" | "1900-01-01" | "@field_id" pour cross-field
  maxDate    String? // "today" | "@field_id"

  // Validateurs natifs belges (logique prédéfinie dans lib/documents/validators.ts)
  belgianType String? // "niss" | "iban" | "tva" | "bce" | "postal" | "phone"

  // Cross-field rule simple
  // { type: "after" | "before" | "equals" | "notEquals" | "greaterThan" | "lessThan", fieldId: string }
  crossFieldRule Json?

  // UX
  errorMsg      String
  errorMsgNl    String?
  helpText      String?
  helpTextNl    String?
  placeholder   String?
  placeholderNl String?

  // Meta
  builtin    Boolean  @default(false) // ne peut pas être supprimé via UI
  icon       String? // nom d'icône lucide
  color      String?
  usageCount Int      @default(0) // analytics: combien de champs l'utilisent
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category])
  @@index([fieldType])
  @@index([builtin])
}

/// Trace d'audit pour une signature électronique apposée sur un document généré.
/// Stocke la signature elle-même + métadonnées prouvant qui a signé quoi et quand.
model SignatureRecord {
  id                  String            @id @default(cuid())
  generatedDocumentId String            @unique
  generatedDocument   GeneratedDocument @relation(fields: [generatedDocumentId], references: [id], onDelete: Cascade)

  // Signataire
  signerName   String
  signerEmail  String?
  signerUserId String?

  // Données signature (image dessinée ou tapée)
  signatureImageData String? // data URL base64 (PNG)
  signatureMethod    String  @default("drawn") // drawn | uploaded | typed

  // Audit trail
  ipAddress String?
  userAgent String?

  // Intégrité du document
  pdfHashBefore String // SHA256 du PDF avant signature
  pdfHashAfter  String // SHA256 du PDF signé
  payloadHash   String // SHA256 du payload du formulaire

  // Horodatage signé optionnel (PAdES) — null si signature simple
  certThumbprint String?
  signedAt       DateTime @default(now())

  @@index([signerUserId])
  @@index([signedAt])
}

/// Bundle = groupe de documents générés en cascade pour un parcours utilisateur.
/// Ex: "Demande de chômage complète" = C1 + C4 + Annexe 27.
model DocumentBundle {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  color       String   @default("#7C3AED")
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items DocumentBundleItem[]

  @@index([active])
}

model DocumentBundleItem {
  id         String           @id @default(cuid())
  bundleId   String
  bundle     DocumentBundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  templateId String
  template   DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order      Int              @default(0)
  required   Boolean          @default(true)
  // Condition d'inclusion: { fieldId: "...", equals: "..." } basée sur les valeurs déjà saisies
  condition  Json?

  @@unique([bundleId, templateId])
  @@index([bundleId])
}

/// Profil utilisateur enrichi pour pré-remplissage des formulaires (Phase 8).
/// Données stockées séparément du modèle User pour pouvoir être null/optionnelles.
model UserProfile {
  userId        String    @id
  // Identité
  firstName     String?
  lastName      String?
  niss          String?
  birthDate     DateTime?
  birthPlace    String?
  nationality   String?
  gender        String?
  // Adresse
  street        String?
  streetNum     String?
  postalCode    String?
  city          String?
  country       String    @default("BE")
  // Contact
  phone         String?
  mobilePhone   String?
  // Bancaire
  iban          String?
  bic           String?
  // Civil
  maritalStatus String? // single | married | cohabiting | divorced | widowed
  // Pro
  employer      String?
  employerBce   String?
  jobTitle      String?
  contractType  String? // CDI | CDD | interim | independant
  contractStart DateTime?
  // Méta
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
}

/// Événements d'analytics côté formulaire utilisateur (Phase 14).
/// Permet de mesurer abandon, temps par section, erreurs de validation fréquentes.
/// Aucune donnée personnelle stockée — seulement l'ID du template et l'événement.
model FormAnalyticsEvent {
  id         String           @id @default(cuid())
  templateId String
  template   DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  // ID anonyme de session (cookie côté client) pour reconstituer un parcours
  sessionId  String
  userId     String? // si connecté
  // started | section_completed | field_error | preview | abandoned | submitted | signature_started
  eventType  String
  // Pour event=field_error → id du champ. Pour section_completed → nom section.
  contextKey String?
  // Métadonnées libres : { sectionIdx, errorMsg, durationMs, etc. }
  metadata   Json?
  createdAt  DateTime         @default(now())

  @@index([templateId, createdAt])
  @@index([sessionId])
  @@index([eventType])
  @@index([templateId, eventType, createdAt])
}
