// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  user
  partner
  employer
  moderator
  admin
}

enum UserStatus {
  active
  pending
  disabled
  locked
}

enum OrganismeType {
  federal // ONEM, ONP, BCSS, INASTI
  regional // Forem, Actiris, VDAB, ADG
  local // Commune, CPAS
  social // Mutuelle, Caisse de chômage (CAPAC, CSC, CGSLB, FGTB)
  professional // Secrétariat social, fiduciaire
  other
}

enum BureauType {
  CPAS
  COMMUNE
  ONEM
  SYNDICAT
  PERMANENCE
  AUTRE
}

enum BelgianRegion {
  wallonia
  flanders
  brussels
  germanophone
}

model User {
  id                  String     @id @default(cuid())
  name                String
  email               String     @unique
  emailVerified       Boolean    @default(false)
  image               String?
  password            String     @default("")
  role                UserRole   @default(user)
  status              UserStatus @default(active)
  emailVerifiedAt     DateTime?
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime   @default(now())
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  partnerOrganization String?
  /// Segment d'accès du compte : "employeur" | "partenaire" (les citoyens n'ont
  /// pas de compte). null = comptes legacy/admin. Validé via isAudienceId().
  segment             String?
  /// Sous-type partenaire : "onem" | "organisme_paiement" | "service_public" |
  /// "prive_asbl". null pour les employeurs et comptes non-partenaires.
  partnerType         String?
  /// Numéro de TVA belge (forme canonique "BE0123456789"). Obligatoire et
  /// unique pour les comptes employeur ; null sinon. Validé via
  /// normalizeBelgianTVA() (checksum mod-97).
  vatNumber           String?    @unique
  /// Responsable du service partenaire : accès par défaut à l'historique des
  /// rendez-vous de son organisation (cf. outil "/rendez-vous").
  isOrgManager        Boolean    @default(false)
  /// Autorisation explicite d'accès à l'historique des rendez-vous, pour un
  /// membre non-responsable (octroyée individuellement par un admin).
  canViewRdvHistory   Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  sessions            Session[]
  accounts            Account[]

  @@index([role])
  @@index([status])
  @@index([partnerOrganization])
  @@index([segment])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model Page {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  content   Json      @default("[]")
  status    String    @default("draft")
  metaTitle String?
  metaDesc  String?
  ogImage   String?
  themeTokens Json?
  scheduledAt DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  revisions PageRevision[]

  @@index([status])
  @@index([deletedAt])
  @@index([status, slug])
}

model PageRevision {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title     String
  content   Json     @default("[]")
  metaTitle String?
  metaDesc  String?
  ogImage   String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([pageId])
  @@index([createdAt])
}

/// Reusable page-builder block saved by an admin (was localStorage, now shared in DB).
model Snippet {
  id          String   @id @default(cuid())
  name        String
  description String?
  block       Json
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

/// Linked reusable block ("symbol"): pages reference it by id; editing it updates
/// every page that references it (live resolution at render time).
model GlobalBlock {
  id        String   @id @default(cuid())
  name      String
  block     Json
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

/// Page-builder: lightweight page-view events for basic analytics (counts + recent trend).
model PageView {
  id        String   @id @default(cuid())
  slug      String
  referrer  String?
  device    String?
  createdAt DateTime @default(now())

  @@index([slug, createdAt])
  @@index([createdAt])
}

model Activity {
  id           String   @id @default(cuid())
  user         String
  action       String // created, updated, deleted, published, unpublished, error
  resource     String // page, user, comment, setting
  resourceName String
  resourceId   String?
  details      String?
  createdAt    DateTime @default(now())
}

model File {
  id        String      @id @default(cuid())
  name      String
  type      String // "file" or "folder"
  fileType  String? // pdf, docx, xlsx, jpg, etc
  mimeType  String?
  size      Int? // bytes
  sha256    String?
  parentId  String?
  parent    File?       @relation("FileHierarchy", fields: [parentId], references: [id])
  children  File[]      @relation("FileHierarchy")
  isPrivate Boolean     @default(false)
  filePath  String? // relative path on disk
  createdBy String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  usage     FileUsage[]

  @@index([parentId])
  @@index([parentId, type])
  @@index([type])
  @@index([isPrivate])
  @@index([createdBy])
  @@index([sha256])
}

model FileUsage {
  id        String   @id @default(cuid())
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  pageId    String?
  pageSlug  String // slug de la page qui utilise le fichier
  context   String? // description du lieu d'utilisation
  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([pageId])
  @@index([pageSlug])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#7C3AED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ToolSection {
  id          String   @id @default(cuid())
  name        String   @unique // "Chômage", "Emploi", etc.
  description String?
  order       Int      @default(0)
  icon        String?
  tools       Tool[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tool {
  id             String      @id @default(cuid())
  sectionId      String
  section        ToolSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  name           String
  slug           String      @unique // "preavis", "agr", etc.
  description    String
  type           String // "calc_preavis", "calc_agr", "locator", "doc_generator", etc.
  icon           String?
  popular        Boolean     @default(false)
  timeMin        Int?
  order          Int         @default(0)
  active         Boolean     @default(true) // false = caché du catalogue public
  /// Audience minimale qui peut voir l'outil. Hiérarchique : citoyen = visible
  /// par tous, employeur = visible par employeur+partenaire, partenaire =
  /// visible uniquement par partenaire. Sert au filtrage côté pages publiques
  /// (/outils, /employeur, /partenaire) via canViewAudience() dans lib/audience.
  /// Valeurs : "citoyen" | "employeur" | "partenaire".
  audience       String      @default("citoyen")
  /// Accès par ENSEMBLE {segment, partnerType?} — remplace à terme la hiérarchie
  /// de `audience`. Array JSON, ex : [{ "segment": "employeur" }, { "segment":
  /// "partenaire", "partnerType": "service_public" }]. Une règle { "segment":
  /// "citoyen" } rend l'outil public (accessible aux anonymes). Tableau vide =
  /// on retombe sur `audience` (legacy) le temps de la migration. Lu via canUseTool().
  access         Json        @default("[]")
  // Vérification annuelle de la fiabilité des chiffres / formules. L'admin
  // appuie sur "Marquer comme revu" via /api/admin/calculators/[slug]/review
  // → lastReviewedAt = now, nextReviewDue = now + 12 mois. Un bandeau
  // d'alerte s'affiche dans /admin/chomage/outils/calculateurs/[slug]
  // dès que nextReviewDue arrive ou est passé.
  lastReviewedAt DateTime?
  nextReviewDue  DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([sectionId])
  @@index([slug])
  @@index([nextReviewDue])
}

/// Sources officielles attachées à un calculateur citoyen.
/// kind="url"   → URL externe (SPF Finances, Securex, CSC, Moniteur belge…)
/// kind="pdf"   → fichier PDF uploadé via Vercel Blob (barème téléchargeable)
/// kind="image" → capture / scan / diagramme uploadé via Vercel Blob
///
/// Catégorise par grand thème (workbonus, precompte, css, atn, general)
/// pour permettre de filtrer dans l'admin & afficher en groupes côté public.
model CalculatorAsset {
  id          String   @id @default(cuid())
  slug        String // slug du calc, ex "brut-net" (réfère à Tool.slug, sans FK pour simplifier le seed)
  kind        String // "pdf" | "url" | "image"
  label       String // ex "Barème SPF Annexe III 2026"
  description String? // optionnel
  url         String // URL publique (Vercel Blob ou URL externe directe)
  category    String? // "workbonus" | "precompte" | "css" | "atn" | "general" | ...
  fileSize    Int? // bytes (pour les uploads)
  mimeType    String? // "application/pdf", "image/png", …
  year        Int? // année de référence (2026, 2025, …)
  order       Int      @default(0)
  uploadedAt  DateTime @default(now())
  uploadedBy  String? // User.id ou email — pas de FK : on garde l'historique même si l'admin part
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([slug, category])
  @@index([slug, order])
}

model News {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @default("")
  excerpt     String
  category    String
  color       String    @default("#7C3AED")
  emoji       String    @default("📰")
  status      String    @default("draft")
  featured    Boolean   @default(false)
  image       String?
  readingTime Int?
  views       Int       @default(0)
  publishedAt DateTime?
  scheduledAt DateTime?
  createdBy   String
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishedAt])
  @@index([status, publishedAt(sort: Desc)])
  @@index([status, category])
  @@index([featured, status])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("active") // active, unsubscribed
  source    String   @default("actualites")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Changelog {
  id          String   @id @default(cuid())
  version     String   @unique
  publishedAt DateTime
  type        String   @default("feature") // feature | fix | improvement | breaking
  title       String
  description String   @default("")
  changes     Json     @default("[]")
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt(sort: Desc)])
  @@index([type])
}

model InboxEmail {
  id             String   @id @default(cuid())
  // Folder = logical inbox category. Mirrors IMAP folders detected via SPECIAL-USE.
  // Values: "INBOX" | "SENT" | "SPAM" | "ARCHIVE" | "TRASH"
  folder         String   @default("INBOX")
  uid            Int
  uidValidity    String?
  // Headers
  messageId      String?
  inReplyTo      String?
  fromAddress    String
  fromName       String?
  replyToAddress String?
  replyToName    String?
  toAddresses    String   @default("") // JSON array of addresses
  ccAddresses    String   @default("") // JSON array of addresses
  subject        String   @default("")
  // Body (parsed)
  textBody       String   @default("")
  htmlBody       String?
  // Attachments metadata (we don't store file contents — just a list)
  attachments    Json     @default("[]") // [{filename, contentType, size}]
  // Status — mirrored from IMAP \Seen and \Flagged flags (server is authoritative)
  isRead         Boolean  @default(false)
  isFlagged      Boolean  @default(false)
  // Timestamps
  receivedAt     DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([folder, uid])
  @@index([folder, receivedAt(sort: Desc)])
  @@index([isRead])
  @@index([fromAddress])
  @@index([messageId])
  @@index([inReplyTo])
}

model BaremeFile {
  id             String   @id @default(cuid())
  name           String
  filePath       String
  effectiveDate  String
  uploadedAt     DateTime @default(now())
  description    String?
  fileType       String   @default("onem-rates")
  multiplicateur Float?
  // Status:
  //   "active"           = legacy upload (avant le nouveau workflow draft/published)
  //   "draft"            = import nouveau, en attente de validation
  //   "pending_approval" = workflow 4 yeux : 1 approbation reçue, attend la 2ème
  //   "published"        = version validée, source pour les calculateurs
  //   "rejected"         = draft refusé manuellement
  //   "archived"         = version précédemment publiée, remplacée par un plus récent
  status         String   @default("active")

  // Workflow d'import (nouveaux uploads via /api/baremes/import)
  fileHash    String?   @unique // sha256, null pour les BaremeFile legacy
  validFrom   DateTime? // Date de validité parsée (en plus de effectiveDate qui est String legacy)
  summary     Json? // { sheetsDetected, sheetsParsed, sheetsIgnored, amountsExtracted, newEntries, modifiedEntries, removedEntries }
  alerts      Json? // [{ level: 'info'|'warn'|'error', sheet?, message }]
  publishedAt DateTime?
  publishedBy String?

  // 4 yeux : si true, exige 2 approbations distinctes avant published
  requiresApproval Boolean @default(false)

  sheets       BareSheet[]
  amounts      BaremeAmount[]
  approvals    BaremeApproval[]
  publications BaremePublicationLog[]
  createdBy    String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([effectiveDate])
  @@index([status])
  @@index([fileType])
  @@index([validFrom])
  @@index([publishedAt])
}

// Audit log : trace toutes les transitions de statut
model BaremePublicationLog {
  id     String     @id @default(cuid())
  fileId String
  file   BaremeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  // ex: "published" | "rejected" | "archived" | "rollback" | "approved" | "submitted_for_approval"
  action     String
  fromStatus String?
  toStatus   String?

  actorEmail String?
  details    Json? // ex: { archivedPreviousId, approvalsCount, ... }

  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([action])
  @@index([createdAt])
}

// Approbations 4 yeux : 1 par admin, exige 2 distinctes pour publier
model BaremeApproval {
  id     String     @id @default(cuid())
  fileId String
  file   BaremeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  approverEmail String
  approverName  String?
  comment       String?

  createdAt DateTime @default(now())

  @@unique([fileId, approverEmail]) // un approbateur ne peut approuver qu'une fois par fichier
  @@index([fileId])
}

// Catégorie de premier niveau du lookup ONEM (Signaletic, Global, Vérification, Dispo, BCSS, Autre).
// Reflète la nomenclature officielle de services.onem.be/lookupweb.
model LookupCategory {
  id      String @id @default(cuid())
  slug    String @unique // "signaletic", "global", "verification", "dispo", "bcss", "autre"
  labelFr String
  labelNl String
  order   Int    @default(0)

  tables LookupTable[]

  @@index([order])
}

// Table individuelle d'un référentiel (ex: "S04/S36 - Article d'indemnisation").
// Chaque table peut être alimentée par un import CSV exporté depuis le lookup ONEM.
model LookupTable {
  id         String         @id @default(cuid())
  categoryId String
  category   LookupCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  slug       String // "s04-s36-article-indemnisation"
  prefix     String // "S04/S36", "S01", "A27", "H33"
  labelFr    String
  labelNl    String
  group      String? // sous-groupe pour la cat. Global (ex: "Chômage", "Adresse")
  // URL relative de la table sur services.onem.be/lookupweb (pour le lien "voir source")
  sourcePath String?
  // Nom interne ONEM (anglais) tel qu'utilisé dans les exports CSV.
  // Ex: "SignaleticCompensationArticle" → fichier "SignaleticCompensationArticle-export_fr.csv".
  // Permet un match exact lors de l'auto-détection du batch upload.
  exportName String?

  // Métadonnées du dernier import
  lastImportedAt   DateTime?
  lastImportedBy   String?
  lastImportSource String? // ex: "csv-onem-export-20260522.csv"
  entriesCount     Int       @default(0)

  notes String? // annotations admin libres

  // Libellé "Mise à jour le …" affiché en haut de la vue table publique.
  // Saisi manuellement par l'admin (ex: "08/12/2025" ou "décembre 2025").
  // Texte libre volontaire : laisse le choix du format à l'admin, et reste
  // vide tant que non renseigné (la mention est alors masquée côté public).
  updatedLabel String?

  // Workflow 4 yeux : si true, les modifications nécessitent 2 approbations.
  requiresApproval Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries   LookupEntry[]
  approvals LookupApproval[]

  @@unique([categoryId, slug])
  @@index([prefix])
  @@index([categoryId, group])
}

// Approbation 4 yeux pour les changements sur une LookupTable sensible.
// Quand un admin édite une table requiresApproval=true, ses modifications sont
// "pending" jusqu'à ce qu'un second admin distinct approuve.
model LookupApproval {
  id      String      @id @default(cuid())
  tableId String
  table   LookupTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  approverEmail String
  approverName  String?
  comment       String?

  // Snapshot du changeset au moment de l'approbation (debug/audit)
  changeset Json?

  createdAt DateTime @default(now())

  @@unique([tableId, approverEmail])
  @@index([tableId])
}

// Entrée individuelle (code + libellés FR/NL + validité temporelle).
// Un même code peut exister en plusieurs versions (différentes validFrom).
model LookupEntry {
  id      String      @id @default(cuid())
  tableId String
  table   LookupTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  code       String // "01AINT", "27,2A1", "28&3,3", "44N"…
  labelFr    String
  labelNl    String
  labelDe    String? // Description allemande (les CSV ONEM la fournissent, souvent vide)
  labelEn    String? // Description anglaise (idem, souvent vide)
  validFrom  DateTime?
  validUntil DateTime? // null = toujours valide

  // Colonnes spécifiques à la table source ONEM (ex: pour UnemploymentOffice :
  // téléphone, IBAN, adresse ; pour BCPost : BC, régime linguistique, région ;
  // pour SignaleticCompensationArticle : flag S04/S36, allocations familiales, etc.)
  // Stocké en clé:valeur pour préserver la richesse du CSV ONEM sans avoir
  // à créer un schéma rigide par table.
  metadata Json?

  notes String? // annotation interne libre

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tableId, code, validFrom])
  @@index([tableId, code])
  @@index([validFrom, validUntil])
  @@index([code]) // recherche transverse
}

// Mapping manuel : override de structure pour un onglet dont la mise en page a changé
// Si présent et matché par sheetName + fileType, le parser utilise ce mapping plutôt
// que la détection auto. Permet d'absorber un changement ONEM sans déployer de code.
model BaremeSheetMapping {
  id String @id @default(cuid())

  // Cible
  sheetName String
  fileType  String @default("onem-rates")

  // Type de parser à utiliser : "allocation_matrix" | "salary_brackets" | "basic_amounts" | "hourly_wages" | ...
  parserType String

  // Catégorie à attribuer aux montants extraits (BaremeCategory)
  category String

  // Configuration spécifique au parser (positions de colonnes, mots-clés de header, etc.)
  // ex pour allocation_matrix : { headerKeyword: "Code", trancheCol: 0 }
  // ex pour basic_amounts : { articleCol: 0, amountCol: 3, unitCol: 4 }
  config Json

  // Notes admin (optionnel)
  notes String?

  enabled   Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sheetName, fileType])
  @@index([fileType])
  @@index([enabled])
}

model BaremeAmount {
  id     String     @id @default(cuid())
  fileId String
  file   BaremeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  sourceSheet String // ex: "A_N_B_vol_plein"
  category    String // "full_unemployment" | "salary_bracket" | "basic_amount" | ...

  allocationCode String? // ex: "AA1"
  salaryCode     String? // ex: "MIN" ou "29"
  article        String? // ex: "art. 114, § 5"

  labelFr String?
  labelNl String?

  unit   String? // "daily" | "monthly" | "yearly" | "hourly" | "rate"
  amount Decimal @db.Decimal(14, 4)

  // Pour tranches salariales
  minDailySalary Decimal? @db.Decimal(14, 4)
  maxDailySalary Decimal? @db.Decimal(14, 4)

  validFrom DateTime?
  rawData   Json? // pour debug/traçabilité (cellule source, valeurs alternatives)

  // Clé stable pour comparer les versions: ex "full_unemployment:AA1:MIN" ou "basic_amount:art_114_5"
  comparisonKey String

  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([category])
  @@index([allocationCode])
  @@index([salaryCode])
  @@index([validFrom])
  @@index([comparisonKey])
}

model BareSheet {
  id     String     @id @default(cuid())
  fileId String
  file   BaremeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String
  rowCount    Int
  colCount    Int     @default(0)

  // Données de la grille en JSON: [[cell1, cell2, ...], [cell1, ...], ...]
  cellData   String @default("[]")
  // Texte concaténé pour recherche full-text
  searchText String @default("")
  // Position dans le workbook
  sheetIndex Int    @default(0)

  createdAt DateTime @default(now())

  @@unique([fileId, name])
  @@index([fileId])
  @@index([category])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model CommissionParitaire {
  id             String   @id @default(cuid())
  code           String   @unique
  numero         String
  numeroOfficiel String
  codeOfficiel5  String
  suffixeInterne String
  type           String
  nom            String
  label          String
  searchText     String
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bureauCommissions BureauCommission[]

  @@index([type])
  @@index([numeroOfficiel])
  @@index([code])
}

/// Liste d'autorisations d'inscription, curée par l'admin. Une entrée autorise
/// soit un domaine email entier (kind="domain", ex "cpas.be"), soit une adresse
/// précise (kind="email", ex "jean@gmail.com" pour le privé sans domaine pro).
/// Chaque entrée porte le segment + le sous-type partenaire à appliquer au
/// compte créé. (Nom historique "PartnerDomain" — couvre désormais aussi les
/// employeurs et les entrées par email.)
model PartnerDomain {
  id               String   @id @default(cuid())
  // "domain" | "email" — granularité du match
  kind             String   @default("domain")
  // Domaine (kind="domain"), ex "cpas.brussels" sans le @. null si kind="email".
  domain           String?  @unique // ex: "cpas.brussels" (sans le @)
  // Adresse email exacte (kind="email"). null si kind="domain".
  email            String?  @unique
  // Segment appliqué au compte créé : "employeur" | "partenaire".
  segment          String   @default("partenaire")
  // Sous-type partenaire (si segment="partenaire") : "onem" | "organisme_paiement"
  // | "service_public" | "prive_asbl". null pour les employeurs.
  partnerType      String?
  organizationName String
  notes            String?
  isTest           Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
  @@index([segment])
}

model U1Institution {
  id            String   @id @default(cuid())
  country       String   @unique
  countryCode   String?
  organization  String
  department    String?
  alternateName String?
  addressLines  Json     @default("[]")
  postalAddress String?
  phone         String?
  fax           String?
  website       String?
  emails        Json     @default("[]")
  extra         Json?
  updatedBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([country])
}

// =====================================================================
// Documents — extension organismes / presets / signatures / bundles
// =====================================================================

/// Organisme émetteur d'un document (ONEM, CPAS, mutuelle, etc.).
/// Utilisé pour grouper et filtrer les modèles dans l'admin.
model Organisme {
  id          String        @id @default(cuid())
  code        String        @unique // "onem", "cpas", "capac", "csc", etc.
  name        String // "Office National de l'Emploi"
  shortName   String? // "ONEM"
  type        OrganismeType @default(other)
  color       String        @default("#7C3AED")
  logoUrl     String?
  website     String?
  description String?
  active      Boolean       @default(true)
  order       Int           @default(0)
  createdBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  bureaus   Bureau[]
  pdfForms  PdfForm[] @relation("OrganismePdfForms")

  @@index([type])
  @@index([active])
  @@index([order])
}

/// Preset de validation réutilisable pour les champs de formulaire.
/// Permet de définir une fois "Nom de famille" et de l'appliquer à tous les docs.
/// Les presets builtin sont seedés et non supprimables.
///
/// **Bibliothèque canonique** : depuis migration 13, les presets servent aussi
/// de "templates de champs" (defaultLabel + dimensions par défaut) pour le
/// click-to-place dans l'éditeur visuel. `popular=true` les met dans la palette
/// rapide.
model FieldValidationPreset {
  id          String  @id @default(cuid())
  name        String  @unique // "Nom de famille", "Date passée", "Salaire mensuel"
  description String?
  category    String  @default("custom") // identity | contact | address | bank | employer | social | document | other
  fieldType   String // text | textarea | number | date | select | checkbox | etc.

  // Bibliothèque canonique (migration 13)
  /// Label par défaut affiché quand le champ est placé via la palette.
  /// Si null, on retombe sur `name`.
  defaultLabel   String?
  /// Largeur par défaut en points PDF quand placé via la palette.
  defaultWidth   Int?
  /// Hauteur par défaut en points PDF.
  defaultHeight  Int?
  /// Valeur par défaut (ex. "Belgique" pour le champ Pays).
  defaultValue   String?
  /// Options par défaut pour type=select : `[{value, label}, ...]`.
  /// Stocké en JSON ; chaque option : { value: string, label: string, labelNl?, labelDe? }.
  defaultOptions Json?
  /// Si true, apparaît dans la palette rapide (8-12 max recommandés).
  popular        Boolean @default(false)

  // Validation rules (toutes optionnelles, combinées en AND)
  regex      String?
  regexFlags String? // ex: "i" pour case insensitive
  minLength  Int?
  maxLength  Int?
  minValue   Float? // pour number
  maxValue   Float?
  minDate    String? // "today" | "1900-01-01" | "@field_id" pour cross-field
  maxDate    String? // "today" | "@field_id"

  // Validateurs natifs belges (logique prédéfinie dans lib/documents/validators.ts)
  belgianType String? // "niss" | "iban" | "tva" | "bce" | "postal" | "phone"

  // Cross-field rule simple
  // { type: "after" | "before" | "equals" | "notEquals" | "greaterThan" | "lessThan", fieldId: string }
  crossFieldRule Json?

  // UX
  errorMsg      String
  errorMsgNl    String?
  helpText      String?
  helpTextNl    String?
  placeholder   String?
  placeholderNl String?

  // Meta
  builtin    Boolean  @default(false) // ne peut pas être supprimé via UI
  icon       String? // nom d'icône lucide
  color      String?
  usageCount Int      @default(0) // analytics: combien de champs l'utilisent
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category])
  @@index([fieldType])
  @@index([builtin])
}

/// Bundle = groupe de documents générés en cascade pour un parcours utilisateur.
/// Ex: "Demande de chômage complète" = C1 + C4 + Annexe 27.
///
/// Un bundle peut aussi représenter un **événement de vie** (ex. "J'ai perdu
/// mon emploi") affiché sur la page d'onboarding. Le mapping se fait via
/// `lifeEventCategory` + `showOnOnboarding`.
model DocumentBundle {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  icon        String?
  color       String  @default("#7C3AED")
  active      Boolean @default(true)
  order       Int     @default(0)

  // Onboarding ("Quelle est ma situation ?") — page d'accueil dédiée
  /// Catégorie d'événement de vie : "emploi", "formation", "famille", "logement", "sante"…
  /// Sert au regroupement visuel sur l'onboarding.
  lifeEventCategory String?
  /// Si true, ce bundle apparaît dans la grille principale de /onboarding.
  showOnOnboarding  Boolean @default(false)
  /// Tags / synonymes pour la recherche libre et la détection d'intention.
  /// Ex: ["chômage temporaire", "intempéries", "chômage technique", "mise au chômage"]
  vocabularyTags    Json    @default("[]")

  /// Questions de pré-qualification informatives, posées AVANT de démarrer le parcours.
  /// Format: EligibilityQuestion[] (cf. lib/bundles/eligibility.ts).
  /// Le résultat est purement informatif, ne bloque JAMAIS la suite.
  eligibilityQuestions Json @default("[]")

  /// Avertissements importants affichés en tête de parcours (ex. EC32 à installer
  /// avant le 1er du mois). Format: BundleWarning[] (cf. lib/bundles/types.ts).
  warnings Json @default("[]")

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items DocumentBundleItem[]
  runs  BundleRun[]

  @@index([active])
  @@index([showOnOnboarding])
  @@index([lifeEventCategory])
}

/// Un item d'un bundle = une référence vers un `PdfForm`.
/// La colonne historique `templateId` est conservée comme nullable
/// pour préserver d'éventuelles lignes existantes ; les nouveaux items
/// référencent uniquement `pdfFormId`.
model DocumentBundleItem {
  id         String         @id @default(cuid())
  bundleId   String
  bundle     DocumentBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  templateId String?
  pdfFormId  String?
  pdfForm    PdfForm?       @relation(fields: [pdfFormId], references: [id], onDelete: Cascade)
  order      Int            @default(0)
  required   Boolean        @default(true)
  // Condition d'inclusion : tableau de règles ANDées (V1) ou arbre AND/OR (V2).
  condition  Json?

  @@unique([bundleId, pdfFormId])
  @@index([bundleId])
  @@index([pdfFormId])
}

/// Run d'un bundle = progression d'un utilisateur (anonyme via sessionId, ou userId).
/// Stocke les payloads validés des documents complétés.
/// Permet d'évaluer les conditions des items à compléter.
model BundleRun {
  id                   String         @id @default(cuid())
  bundleId             String
  bundle               DocumentBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  // Identification utilisateur (l'un des trois)
  userId               String?
  sessionId            String? // cookie côté client
  /// Code de reprise lisible par l'utilisateur (ex. "BELDOC-3X7K-9P2M").
  /// Permet de reprendre un dossier depuis un autre appareil / après expiration du cookie.
  /// Généré au premier `POST /api/documents/bundles/[id]/run` quand le run est créé.
  resumeCode           String?        @unique
  resumeCodeExpiresAt  DateTime? // TTL par défaut = 30 jours
  /// Email optionnel saisi par l'utilisateur pour se faire envoyer le code par mail.
  /// Pas une donnée d'identification — purement pratique pour la reprise.
  resumeEmail          String?
  // Payloads collectés : { [templateId]: { ...validated payload } }
  payloads             Json           @default("{}")
  /// Réponses au questionnaire de pré-qualification (informatif).
  /// Clé : questionId. Valeur : réponse de l'utilisateur.
  eligibilityAnswers   Json           @default("{}")
  // Liste des templateIds complétés (ordre d'achèvement)
  completedTemplateIds Json           @default("[]")
  status               String         @default("in_progress") // in_progress | completed | abandoned
  startedAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  completedAt          DateTime?

  @@index([bundleId])
  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@index([resumeCodeExpiresAt])
}

/// Profil utilisateur enrichi pour pré-remplissage des formulaires (Phase 8).
/// Données stockées séparément du modèle User pour pouvoir être null/optionnelles.
model UserProfile {
  userId                  String    @id
  // Identité
  firstName               String?
  lastName                String?
  niss                    String?
  birthDate               DateTime?
  birthPlace              String?
  nationality             String?
  gender                  String?
  // Adresse
  street                  String?
  streetNum               String?
  postalCode              String?
  city                    String?
  country                 String    @default("BE")
  // Contact
  phone                   String?
  mobilePhone             String?
  // Bancaire
  iban                    String?
  bic                     String?
  // Civil
  maritalStatus           String? // single | married | cohabiting | divorced | widowed
  // Pro
  employer                String?
  employerBce             String?
  jobTitle                String?
  contractType            String? // CDI | CDD | interim | independant
  contractStart           DateTime?
  // Préférences administratives (pour résolveur bureaux)
  organismePaiement       String? // "capac" | "fgtb" | "csc" | "cgslb"
  commissionParitaireCode String? // ref CommissionParitaire.code (ex: "124")
  mutuelleCode            String? // "solidaris" | "mc" | "mloz" | "mutlibres" | "neutrales"
  // Méta
  updatedAt               DateTime  @updatedAt
  createdAt               DateTime  @default(now())
}

/// Mémoire des corrections OCR : apprend des modifications admin pour
/// proposer la même correction sur les détections futures (fuzzy match du label).
model OcrCorrectionMemory {
  id          String   @id @default(cuid())
  templateId  String? // null = correction globale (cross-templates)
  rawLabel    String // label détecté à l'origine par l'OCR
  cleanLabel  String // version corrigée par l'admin
  fieldType   String? // type éventuellement remplacé (text → niss, etc.)
  presetId    String? // preset éventuellement appliqué
  occurrences Int      @default(1)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([templateId, rawLabel])
  @@index([rawLabel])
}

/// Snapshot d'une détection OCR pour un PDF donné (clé : SHA256 du fichier).
/// Permet de restaurer instantanément le schema sans relancer l'OCR
/// quand le même PDF est ré-uploadé ou réutilisé sur un autre template.
model OcrSnapshot {
  id             String   @id @default(cuid())
  sha256         String   @unique
  fileId         String?
  detectedFields Json // DetectedField[] avec inférences appliquées
  pageCount      Int
  templateId     String? // template source (informatif)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sha256])
  @@index([fileId])
}

// =====================================================================
// Bureaux — annuaire des bureaux CPAS / Commune / ONEM / Syndicats
// =====================================================================

/// Commune belge (fusion 2025) avec son code INS officiel.
/// Identifiant pivot pour la résolution code postal → bureau attitré.
model Commune {
  id           String        @id @default(cuid())
  insCode      String        @unique // "21001" Anderlecht, "11001" Aartselaar...
  nameFr       String
  nameNl       String?
  nameDe       String?
  region       BelgianRegion
  province     String? // "liege", "hainaut", "namur", "luxembourg", "brabant-wallon", "antwerpen"...
  // Centroïde de la commune pour fallback géoloc et calcul distance par CP
  lat          Float?
  lng          Float?
  // Si fusion ultérieure : redirige vers la nouvelle commune
  mergedIntoId String?
  mergedInto   Commune?      @relation("CommuneFusion", fields: [mergedIntoId], references: [id])
  fusedFrom    Commune[]     @relation("CommuneFusion")

  postalCodes PostalCode[]
  bureaus     Bureau[]           @relation("BureauCommune")
  assignments BureauAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([region])
  @@index([nameFr])
}

/// Code postal belge → commune principale.
/// Note : un CP partagé entre plusieurs communes pointe sur la commune dominante.
model PostalCode {
  code      String  @id // "1000", "4020", etc.
  communeId String
  commune   Commune @relation(fields: [communeId], references: [id], onDelete: Cascade)

  @@index([communeId])
}

/// Bureau physique (CPAS, Maison communale, ONEM, antenne syndicale, permanence).
/// Pour CPAS/Commune : 1 bureau ↔ 1 commune (communeId rempli).
/// Pour ONEM : assignment via BureauAssignment (1 bureau dessert N communes).
/// Pour Syndicat/Permanence : libre choix géographique, communeId optionnel.
model Bureau {
  id             String     @id @default(cuid())
  organismeId    String
  organisme      Organisme  @relation(fields: [organismeId], references: [id])
  type           BureauType
  name           String // "CPAS de Saint-Gilles"
  // Localisation
  street         String
  streetNum      String?
  postalCode     String
  city           String
  lat            Float?
  lng            Float?
  // Compétence territoriale (pour CPAS/COMMUNE = obligatoire)
  communeId      String?
  commune        Commune?   @relation("BureauCommune", fields: [communeId], references: [id])
  // Contact
  phone          String?
  email          String?
  website        String?
  appointmentUrl String?
  // Horaires structurés : [{day: 1, slots: [{open: "09:00", close: "12:00"}, ...]}]
  // day: 0=dimanche, 1=lundi, ... 6=samedi
  hours          Json       @default("[]")
  hoursNotes     String?
  // Services rendus ici (codes libres : "RIS", "aide_juridique", "domiciliation", ...)
  services       Json       @default("[]")
  // Méta
  active         Boolean    @default(true)
  notes          String?
  // Vérification : pour signaler que les coordonnées sont à jour.
  verified       Boolean    @default(false)
  lastVerifiedAt DateTime?
  verifiedBy     String?
  // Identifiants ONEM (pour les bureaux type=onem, sync depuis lookup
  // bureau-de-chomage). Permet le cross-ref avec parametres-onem-cp pour
  // les assignations CP→BC automatiques.
  numeroOnem     String? // "11", "12"... = numéro de bureau de chômage
  regionOnem     String? // "Bruxelles", "Wallonie", "Flandre"…
  clusterOnem    String? // numéro de cluster ONEM
  // i18n labels optionnels
  nameNl         String?
  nameDe         String?
  updatedBy      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  assignments BureauAssignment[]
  revisions   BureauRevision[]
  reports     BureauReport[]
  commissions BureauCommission[]

  @@index([organismeId, type])
  @@index([type])
  @@index([communeId])
  @@index([postalCode])
  @@index([active])
  @@index([verified])
  @@index([lastVerifiedAt])
  @@index([numeroOnem])
}

/// Lie un bureau (sectoriel / syndicat / mutuelle) à une commission paritaire.
/// Permet : "je travaille en CP 124 (construction) → voici les bureaux compétents".
model BureauCommission {
  bureauId     String
  bureau       Bureau              @relation(fields: [bureauId], references: [id], onDelete: Cascade)
  commissionId String
  commission   CommissionParitaire @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  role         String              @default("general") // "centrale_sectorielle" | "permanence" | "general"
  createdAt    DateTime            @default(now())

  @@id([bureauId, commissionId])
  @@index([commissionId])
  @@index([bureauId])
}

/// Snapshot d'un bureau avant modification — permet rollback / audit.
model BureauRevision {
  id          String   @id @default(cuid())
  bureauId    String
  bureau      Bureau   @relation(fields: [bureauId], references: [id], onDelete: Cascade)
  // Snapshot complet (JSON) du bureau avant la modification
  snapshot    Json
  // Diff calculé : { changed: ["phone", "hours"], previous: {...}, current: {...} }
  diff        Json?
  changeNotes String?
  changedBy   String?
  createdAt   DateTime @default(now())

  @@index([bureauId, createdAt(sort: Desc)])
  @@index([changedBy])
}

/// Signalement public d'erreur sur un bureau (horaires obsolètes, adresse fausse, etc.).
model BureauReport {
  id            String    @id @default(cuid())
  bureauId      String
  bureau        Bureau    @relation(fields: [bureauId], references: [id], onDelete: Cascade)
  // Type d'erreur signalée
  category      String // "hours" | "address" | "phone" | "closed" | "other"
  message       String
  // Contact optionnel pour follow-up
  reporterEmail String?
  // Métadonnées (pas de PII)
  ipHash        String?
  userAgent     String?
  // Workflow admin
  status        String    @default("pending") // pending | resolved | dismissed
  resolvedBy    String?
  resolvedAt    DateTime?
  adminNotes    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([bureauId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

/// Lie un bureau ONEM à toutes les communes qu'il dessert (compétence territoriale).
/// serviceType permet d'ajouter d'autres services à l'avenir (ex: "famille").
model BureauAssignment {
  bureauId    String
  communeId   String
  serviceType String  @default("chomage")
  bureau      Bureau  @relation(fields: [bureauId], references: [id], onDelete: Cascade)
  commune     Commune @relation(fields: [communeId], references: [id], onDelete: Cascade)

  @@id([bureauId, communeId, serviceType])
  @@index([communeId, serviceType])
  @@index([bureauId])
}

// =====================================================================
// Chômage IA — Knowledge base + chat persistent + prompt builder
// =====================================================================

/// Source de connaissance déposée dans la KB de l'assistant IA chômage.
/// Une "source" = un bloc autosuffisant d'information cité par l'IA dans
/// ses réponses : article de loi, AR ONEM, tutoriel pas-à-pas, transcript
/// vidéo, caption d'image / diagramme, URL externe, PDF d'archive.
///
/// `kind` :
///   "text"             → contenu rédigé directement dans l'admin
///   "url"              → URL externe (avec contenu optionnel scrappé/manuel)
///   "tutorial"         → étapes d'une démarche (markdown structuré)
///   "video_transcript" → transcription d'une vidéo (avec timecodes possibles)
///   "image_caption"    → description d'une image / diagramme + image attachée
///   "pdf"              → PDF uploadé, contenu = texte extrait
///
/// `enabled=false` → la source reste en DB mais n'est plus injectée dans le
/// contexte envoyé à Claude (pause sans perte).
///
/// `fileId` : ID du File uploadé (PDF / image), null pour les sources texte/URL.
model KnowledgeSource {
  id          String   @id @default(cuid())
  title       String
  kind        String
  content     String   @db.Text
  summary     String?  @db.Text
  sourceUrl   String?
  fileId      String?
  tags        String[] @default([])
  enabled     Boolean  @default(true)
  domain      String   @default("chomage")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  /// Timestamp du dernier indexing RAG réussi (migration 19, pgvector).
  /// Null = jamais indexé (ou en attente). Mis à jour par `indexKnowledgeSource`.
  indexedAt  DateTime?
  /// Dernier message d'erreur d'indexing (provider down, content trop court…).
  /// Null = pas d'erreur ou pas encore indexé.
  indexError String?

  /// Migration 21 — dossier de classement (null = racine "Sans dossier").
  /// Différent de ChatFolder (qui range les sessions). Cf. KnowledgeFolder.
  folderId String?
  folder   KnowledgeFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  /// Migration 22 — détection d'obsolescence (Feature 3).
  /// `lastValidatedAt` : null tant que l'admin n'a jamais cliqué "Toujours en vigueur".
  /// `validityStatus`  : "unknown" (défaut), "fresh", "stale" (>12 mois), "obsolete" (>24 mois).
  lastValidatedAt DateTime?
  validityStatus  String    @default("unknown")

  /// Chunks RAG (1 source → N chunks). Cascade delete via FK.
  chunks KnowledgeChunk[]

  @@index([domain, enabled])
  @@index([createdAt])
  @@index([domain, folderId])
  @@index([domain, validityStatus])
}

/// Dossier hiérarchique pour ranger les KnowledgeSource (migration 21).
///
/// Différent de ChatFolder (qui range les ChatSession) — ici on range
/// les *sources* de la knowledge base. Permet :
///   - Une arborescence à 3 niveaux max (parentId auto-référence).
///   - Une couleur + une icône pour l'identification visuelle dans la sidebar.
///   - Le drag&drop des sources entre dossiers (front + bulk API).
///
/// Le scope multi-folder est lu depuis ChatSession.scopeFolderIds — quand non
/// vide, le retrieval RAG filtre les sources sur `folderId IN (...)`.
model KnowledgeFolder {
  id          String            @id @default(cuid())
  name        String
  /// Hex (#3b82f6) ou nom Tailwind ("blue", "amber") — front décide du rendu.
  color       String?
  /// Nom d'icône lucide-react (ex. "Folder", "BookOpen"). Défaut "Folder" si null.
  icon        String?
  parentId    String?
  parent      KnowledgeFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    KnowledgeFolder[] @relation("FolderHierarchy")
  order       Int               @default(0)
  domain      String            @default("chomage")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdById String?

  sources KnowledgeSource[]

  @@index([domain, parentId, order])
  @@index([parentId])
}

/// Chunk d'une `KnowledgeSource` indexé avec son embedding pour la RAG sémantique.
/// Migration 19 active l'extension pgvector et déclare la colonne SQL `embedding`
/// en `vector(1536)` (1536 = dim OpenAI text-embedding-3-small ; Voyage 3-lite
/// renvoie du 1024, paddé à 1536 côté indexer pour partager la même colonne).
///
/// Prisma ne supporte pas le type `vector` nativement — on déclare donc `embedding`
/// comme `Bytes?` ici (placeholder) et on fait toutes les écritures + lectures
/// vectorielles via raw queries (`prisma.$executeRawUnsafe` / `prisma.$queryRawUnsafe`)
/// dans `lib/chomage-ia/indexer.ts` et `lib/chomage-ia/context.ts`.
model KnowledgeChunk {
  id          String          @id @default(cuid())
  sourceId    String
  source      KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  /// Ordre dans la source originale (0, 1, 2, …).
  chunkIndex  Int
  content     String          @db.Text
  /// sha256(content) — permet de skipper l'embedding si inchangé entre 2 runs.
  contentHash String
  /// Placeholder Prisma — la colonne SQL réelle est `vector(1536)`.
  /// Ne PAS utiliser via Prisma client : faire des raw queries.
  embedding   Bytes?          @db.ByteA
  /// Dimension réelle du vector (ex. 1024 voyage-3-lite, 1536 openai-3-small).
  embedDim    Int
  /// Modèle d'embedding utilisé (ex. "voyage-3-lite", "text-embedding-3-small").
  embedModel  String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([sourceId, chunkIndex])
  @@index([embedModel])
}

/// Session de chat IA — un fil de discussion entre l'admin et l'assistant.
/// `title` est généré automatiquement à partir du premier message (ou éditable
/// manuellement plus tard). On scope par `domain` pour permettre des chats
/// dédiés à des thématiques différentes plus tard (chômage, sécu, etc.).
///
/// Power features (migration 17) :
///   - `pinned` : épingle la session en haut du rail (badge visuel).
///   - `archived` : sort la session de la liste principale sans la supprimer.
///   - `folderId` : range la session dans un dossier de groupement coloré.
///
/// Migration 18 :
///   - `preferredModel` : modèle Claude forcé pour cette session (null = défaut Sonnet).
///     Valeurs autorisées : valeurs de `CLAUDE_MODELS` (sonnet | haiku).
model ChatSession {
  id             String        @id @default(cuid())
  title          String        @default("Nouvelle conversation")
  domain         String        @default("chomage")
  pinned         Boolean       @default(false)
  archived       Boolean       @default(false)
  folderId       String?
  folder         ChatFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  preferredModel String?
  /// Migration 21 — scope multi-folder pour limiter le retrieval RAG.
  /// Tableau vide `[]` = toute la KB (défaut, rétrocompatible avec sessions
  /// pré-migration 21). Liste d'IDs = filtre `KnowledgeSource.folderId IN (...)`.
  /// NB : on stocke des IDs *de KnowledgeFolder*, pas de ChatFolder.
  scopeFolderIds String[]      @default([])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       ChatMessage[]
  createdById    String?

  @@index([domain, createdAt])
  @@index([domain, pinned, archived])
  @@index([folderId])
}

/// Dossier de groupement coloré pour ranger les ChatSession.
/// Couleurs : hex ("#7C3AED") ou nom Tailwind ("blue", "amber") au choix
/// — le front décidera comment matcher (palette préset côté UI).
model ChatFolder {
  id          String        @id @default(cuid())
  name        String
  color       String?
  order       Int           @default(0)
  domain      String        @default("chomage")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById String?
  sessions    ChatSession[]

  @@index([domain, order])
}

/// Message individuel d'une session de chat.
/// `citedSourceIds` : IDs KnowledgeSource cités par l'assistant dans son
/// message (extraits par regex sur les marqueurs [SRC:id]).
/// `tokensIn` / `tokensOut` : pour suivre le coût et faire des analytics.
model ChatMessage {
  id             String      @id @default(cuid())
  sessionId      String
  session        ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role           String
  content        String      @db.Text
  citedSourceIds String[]    @default([])
  model          String?
  tokensIn       Int?
  tokensOut      Int?
  createdAt      DateTime    @default(now())

  @@index([sessionId, createdAt])
}

/// Prompt Claude Code généré via le prompt-builder.
/// Conserve l'historique pour ré-utilisation et amélioration du système.
/// `brief` = consigne libre de l'admin ("crée-moi un prompt pour un calc d'AGR").
/// `output` = prompt finalisé prêt à coller dans Claude Code.
model GeneratedPrompt {
  id             String   @id @default(cuid())
  title          String
  brief          String   @db.Text
  output         String   @db.Text
  domain         String   @default("chomage")
  citedSourceIds String[] @default([])
  createdAt      DateTime @default(now())
  createdById    String?

  @@index([domain, createdAt])
}

/// Snippet réutilisable inséré dans la textarea chat / prompt via le command
/// palette `/<shortcut>`. Permet de sauver des phrases / consignes fréquentes
/// (ex: "Vérifie tous les SRC:" ou un pattern récurrent pour les calculateurs).
///
/// `shortcut` : token utilisé pour le matching après le `/`. Unique par domaine.
/// `title`    : libellé affiché dans la liste / palette.
/// `content`  : texte effectivement inséré en remplacement du `/query`.
model ChatSnippet {
  id          String   @id @default(cuid())
  shortcut    String
  title       String
  content     String   @db.Text
  domain      String   @default("chomage")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  @@unique([domain, shortcut])
  @@index([domain, order])
}

/// Migration 22 — mémoire long-terme transversale (Feature 4).
///
/// Faits "permanents" injectés dans toutes les conversations chat IA, en début
/// de contexte. Permet de stocker du vocabulaire (ONEM = …), des préférences
/// utilisateur, des règles de style ("toujours citer les sources publiques").
///
/// `importance` ordonne le bloc injecté (high > medium > low) et sert de
/// critère de troncature si le budget tokens est dépassé (cf. ChatMemory_BUDGET_TOKENS).
model ChatMemory {
  id          String   @id @default(cuid())
  content     String   @db.Text
  importance  String   @default("medium") // "high" | "medium" | "low"
  domain      String   @default("chomage")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  @@index([domain, enabled, importance])
}

/// Migration 22 — gap de connaissance détecté (Feature 6).
///
/// Créé automatiquement par `postProcessChatAnswer` quand la réponse Claude
/// contient un pattern "je n'ai pas d'info précise…" ou une ref légale absente
/// de la KB. L'admin résout les gaps en ajoutant la source correspondante.
///
/// `occurrences` permet de prioriser les questions revenant souvent (groupé
/// par query similaire dans la UI).
model KnowledgeGap {
  id                String   @id @default(cuid())
  query             String   @db.Text
  detectedAt        DateTime @default(now())
  sessionId         String?
  messageId         String?
  status            String   @default("open") // "open" | "resolved" | "ignored"
  resolvedBy        String?
  knowledgeSourceId String?
  notes             String?  @db.Text
  domain            String   @default("chomage")
  occurrences       Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([domain, status, detectedAt(sort: Desc)])
  @@index([sessionId])
}

/// Migration 22 — source de veille (Feature 1).
///
/// Définit une URL RSS ou une page HTML à scraper périodiquement pour détecter
/// de nouveaux documents (ONEM, Moniteur belge, SPF Emploi, etc.). Le cron
/// `/api/chomage-ia/ingestion/cron` itère sur les `enabled=true`, applique la
/// stratégie selon `kind` et alimente `IngestedDocument`.
///
/// `lastError` : dernier message d'erreur ("HTTP 503", "0 documents trouvés"…).
/// `lastSuccessAt` : dernière exécution AYANT trouvé au moins 1 document neuf.
model IngestionSource {
  id            String    @id @default(cuid())
  name          String
  kind          String // "rss" | "scrape"
  url           String
  schedule      String    @default("daily") // "hourly" | "daily" | "weekly"
  enabled       Boolean   @default(true)
  domain        String    @default("chomage")
  lastCheckedAt DateTime?
  lastSuccessAt DateTime?
  lastError     String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  documents IngestedDocument[]

  @@index([domain, enabled])
}

/// Migration 22 — document détecté par la veille en attente de validation.
///
/// `externalUrl` est unique (dédoublonnage entre runs de cron).
/// `status` :
///   - "pending"   → en attente d'examen admin
///   - "validated" → admin a validé : `knowledgeSourceId` pointe sur la KS créée
///   - "rejected"  → admin a refusé (spam / hors-sujet)
model IngestedDocument {
  id                String          @id @default(cuid())
  ingestionSourceId String
  ingestionSource   IngestionSource @relation(fields: [ingestionSourceId], references: [id], onDelete: Cascade)
  externalUrl       String          @unique
  title             String
  publishedAt       DateTime?
  fetchedAt         DateTime        @default(now())
  status            String          @default("pending") // "pending" | "validated" | "rejected"
  knowledgeSourceId String?
  notes             String?         @db.Text

  @@index([status, fetchedAt(sort: Desc)])
  @@index([ingestionSourceId])
}

// =====================================================================
// PDF Forms — nouvelle fonctionnalité (AcroForm only), indépendante de
// DocumentTemplate. Namespace PdfForm*. Aucune dépendance vers les
// modèles Document* afin de pouvoir supprimer l'ancien système à terme.
//
// Principes :
//   - 1 PDF (à champs AcroForm) = 1 formulaire généré côté front.
//   - Schéma à deux niveaux : `technicalSchema` (extraction brute, ancre
//     immuable tant que le PDF source ne change pas) + `fields` (enrichi,
//     librement éditable : labels multilingues, validation, prefill…).
//   - RGPD : le PDF rempli n'est JAMAIS stocké. On ne garde qu'un log
//     d'audit sans donnée nominative (PdfFormSubmissionLog).
//   - Livraison : download one-shot ou envoi via Doccle (Belgique).
//   - Prefill optionnel via itsme (claims OIDC) ou profil utilisateur.
// =====================================================================

enum PdfFormStatus {
  draft
  published
  archived
}

/// Modèle de formulaire PDF. Le PDF source (vierge, officiel) est stocké
/// via lib/pdf-forms/storage (chemin `sourceStoragePath`), découplé du
/// modèle File de l'ancien système.
model PdfForm {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?
  /// Organisme émetteur en texte libre (fallback historique : ONEM, CPAS,
  /// SPF…). Conservé pour les PdfForms importés avant la FK organismeId.
  issuer      String?
  /// Organisme émetteur (référence au modèle Organisme partagé).
  /// Nullable pour ne pas casser les PdfForms existants — l'admin peut
  /// rattacher progressivement les anciens.
  organismeId String?
  organisme   Organisme? @relation("OrganismePdfForms", fields: [organismeId], references: [id], onDelete: SetNull)
  status      PdfFormStatus @default(draft)
  version     Int           @default(1)

  // --- Localisation ---
  /// Locale par défaut (toujours présente). Valeurs : "fr" | "nl" | "de".
  defaultLocale String @default("fr")
  /// Locales disponibles pour ce formulaire, ex ["fr","de"].
  locales       Json   @default("[\"fr\"]")

  // --- PDF source (vierge) ---
  sourceStoragePath String
  sourceFileName    String
  sourceByteSize    Int
  sourceSha256      String
  pageCount         Int    @default(1)

  // --- Schémas ---
  /// Extraction brute de l'AcroForm — AcroFieldRaw[] (cf. lib/pdf-forms/types).
  /// Sert d'ancre de génération ; ne change qu'à un re-parse / nouvelle version.
  technicalSchema Json @default("[]")
  /// Schéma enrichi éditable — PdfFormField[] (cf. lib/pdf-forms/types).
  fields          Json @default("[]")

  // --- Éditeur visuel d'AcroForms (v1 : text + checkbox sur PDF plats) ---
  /// Wrapper VisualFieldsDoc — cf. lib/pdf-forms/visual/types.
  visualFields               Json      @default("{\"version\":1,\"fields\":[]}")
  /// Timestamp de la dernière matérialisation (création des AcroForms réels
  /// dans le PDF source). null = jamais matérialisé.
  visualFieldsMaterializedAt DateTime?

  // --- Livraison ---
  allowDownload Boolean @default(true)
  allowDoccle   Boolean @default(false)
  /// Si true, propose le prefill via itsme côté front.
  allowItsme    Boolean @default(false)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revisions   PdfFormRevision[]
  submissions PdfFormSubmissionLog[]
  drafts      PdfFormDraft[]
  bundleItems DocumentBundleItem[]
  validationReports FormValidationReport[]

  @@index([status])
  @@index([updatedAt])
  @@index([organismeId])
}

/// Historique de versions. Snapshot créé avant chaque changement de schéma
/// ou de PDF source.
model PdfFormRevision {
  id              String   @id @default(cuid())
  formId          String
  form            PdfForm  @relation(fields: [formId], references: [id], onDelete: Cascade)
  version         Int
  fields          Json
  technicalSchema Json
  sourceSha256    String
  sourceFileName  String
  /// "minor" | "major" | "source_update" (= nouveau PDF officiel)
  changeType      String   @default("minor")
  changeNotes     String?
  /// { added: [], removed: [], renamed: [], modified: [] } — cf. lib/pdf-forms/diff
  diffSummary     Json?
  createdBy       String?
  createdAt       DateTime @default(now())

  @@index([formId])
  @@index([createdAt])
}

/// Bibliothèque de presets de champs réutilisables (NISS, IBAN, code postal…).
model PdfFieldPreset {
  id         String  @id @default(cuid())
  key        String  @unique
  label      String
  /// Type sémantique : text|niss|iban|postal_be|phone_be|bce|tva_be|date|number…
  fieldType  String
  regex      String?
  /// Messages d'erreur localisés : { fr, nl?, de? }
  errorMsg   Json?
  helpText   Json?
  maxLength  Int?
  /// true pour les presets fournis d'origine (non supprimables par l'admin).
  builtin    Boolean @default(false)
  usageCount Int     @default(0)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Audit de génération SANS donnée nominative (RGPD).
/// On ne stocke jamais le payload ni le PDF : seulement un hash + métadonnées.
model PdfFormSubmissionLog {
  id          String   @id @default(cuid())
  formId      String
  form        PdfForm  @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion Int
  locale      String
  /// SHA256 du payload validé (intégrité / dédoublonnage), pas le payload.
  payloadHash String
  /// "download" | "doccle"
  delivery    String
  success     Boolean  @default(true)
  /// Hash de l'IP (non réversible) pour stats anti-abus.
  ipHash      String?
  userId      String?
  createdAt   DateTime @default(now())

  @@index([formId])
  @@index([createdAt])
}

/// Brouillon de saisie (formulaires longs). Contient des données nominatives
/// → TTL court + purge cron obligatoire.
model PdfFormDraft {
  id        String   @id @default(cuid())
  formId    String
  form      PdfForm  @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId    String
  payload   Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([formId, userId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// KBO / BCE — Banque-Carrefour des Entreprises (registre belge ouvert).
// Données ouvertes officielles, ingérées mensuellement depuis les CSV publics
// (cf. lib/be-companies/kbo-etl.ts). Utilisé pour autocomplétion en saisie de
// formulaires (BCE → nom + adresse + forme juridique + NACE).
// ---------------------------------------------------------------------------

/// Une entreprise belge enregistrée à la BCE. Identifiée par son numéro
/// d'entreprise (10 chiffres, le BCE = la TVA sans le préfixe BE).
model KboEnterprise {
  /// Numéro BCE sans préfixe (ex. "0123456789"). C'est aussi la TVA sans "BE".
  enterpriseNumber   String    @id
  /// Statut BCE (AC = active, ST = stopped, …).
  status             String?
  /// Situation juridique (000 = normale, 010 = liquidation, …).
  juridicalSituation String?
  /// Type d'entreprise (1 = personne physique, 2 = personne morale).
  typeOfEnterprise   String?
  /// Code forme juridique (017 = SRL, 014 = SA, …).
  juridicalForm      String?
  startDate          DateTime?

  denominations KboDenomination[]
  addresses     KboAddress[]
  activities    KboActivity[]

  updatedAt DateTime @updatedAt
}

/// Dénominations (noms commerciaux, raisons sociales, abréviations) — un
/// même `entityNumber` peut en avoir plusieurs (multilingue + types).
model KboDenomination {
  id                 String  @id @default(cuid())
  enterpriseNumber   String
  /// Langue (0 = sans, 1 = FR, 2 = NL, 3 = DE, 4 = EN).
  language           String?
  /// Type de dénomination (001 = sociale, 002 = abréviation, 003 = commerciale).
  typeOfDenomination String?
  denomination       String

  enterprise KboEnterprise @relation(fields: [enterpriseNumber], references: [enterpriseNumber], onDelete: Cascade)

  @@index([enterpriseNumber])
  @@index([denomination])
}

/// Adresses (siège, succursale). Bilingues FR/NL.
model KboAddress {
  id               String    @id @default(cuid())
  enterpriseNumber String
  /// REGO = siège social, OABR = adresse à l'étranger.
  typeOfAddress    String?
  countryFR        String?
  countryNL        String?
  zipcode          String?
  municipalityFR   String?
  municipalityNL   String?
  streetFR         String?
  streetNL         String?
  houseNumber      String?
  box              String?
  extraAddressInfo String?
  dateStrikingOff  DateTime?

  enterprise KboEnterprise @relation(fields: [enterpriseNumber], references: [enterpriseNumber], onDelete: Cascade)

  @@index([enterpriseNumber])
  @@index([zipcode])
}

/// Activités NACE.
model KboActivity {
  id               String  @id @default(cuid())
  enterpriseNumber String
  activityGroup    String?
  naceVersion      String?
  naceCode         String?
  /// MAIN = principale, SECO = secondaire, ANCI = auxiliaire.
  classification   String?

  enterprise KboEnterprise @relation(fields: [enterpriseNumber], references: [enterpriseNumber], onDelete: Cascade)

  @@index([enterpriseNumber])
  @@index([naceCode])
}

/// Audit des ingestions KBO (état, durée, métriques).
model KboEtlRun {
  id                  String    @id @default(cuid())
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?
  /// "running" | "success" | "error"
  status              String
  fileName            String?
  enterprisesUpserted Int       @default(0)
  errorMessage        String?

  @@index([startedAt])
}

// ---------------------------------------------------------------------------
// Signalements de validation de champ — quand un utilisateur pense qu'un
// message d'erreur est un faux positif (ex. NISS rejeté à tort).
// Anonyme par défaut, RGPD-friendly. Modèle inspiré de BureauReport.
// ---------------------------------------------------------------------------

model FormValidationReport {
  id            String   @id @default(cuid())
  /// Réf. au PdfForm si connu (peut être null si saisi hors contexte form).
  formId        String?
  form          PdfForm? @relation(fields: [formId], references: [id], onDelete: SetNull)
  /// Slug du formulaire au moment du report (utile si le PdfForm est supprimé).
  formSlug      String?
  /// Identifiant du champ dans le schéma du formulaire (cf. PdfFormField.id).
  fieldId       String
  /// Type sémantique du champ : "niss" | "iban" | "tva_be" | "bce" | …
  fieldType     String
  /// Valeur exacte que l'utilisateur a saisie et qui a été rejetée.
  /// L'utilisateur a explicitement consenti (case à cocher dans la dialog).
  rejectedValue String
  /// Message d'erreur affiché à l'utilisateur (déjà localisé).
  errorMessage  String
  /// Locale active au moment du report ("fr" | "nl" | "de").
  locale        String?
  /// Message libre de l'utilisateur (optionnel, max 1000 chars).
  userMessage   String?
  /// Email de contact pour suivi (optionnel).
  reporterEmail String?
  /// Métadonnées non-PII pour debug + anti-abus.
  ipHash        String?
  userAgent     String?
  /// Workflow admin.
  status        String   @default("pending") // pending | resolved | dismissed
  resolvedBy    String?
  resolvedAt    DateTime?
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([formId])
  @@index([status])
  @@index([fieldType])
  @@index([createdAt(sort: Desc)])
}

/// Historique des rendez-vous traités via l'outil "/rendez-vous", pour détecter
/// les doublons (une même personne qui a déjà pris un RDV). Cloisonné par
/// `scope` = organisation partenaire (partage au sein d'un même service).
model RendezVousHistory {
  id             String   @id @default(cuid())
  /// Périmètre de partage : `User.partnerOrganization` (ou `admin:<userId>`).
  scope          String
  /// Nom normalisé (minuscules, sans accents) — clé de comparaison.
  nameNormalized String
  /// Nom tel que collé (graphie d'origine), pour l'affichage.
  name           String
  /// Date murale du RDV au format "YYYY-MM-DD".
  date           String
  /// Heure de début "HH:MM".
  startTime      String
  /// Heure de fin "HH:MM".
  endTime        String
  /// Utilisateur ayant enregistré l'entrée.
  createdById    String
  createdAt      DateTime @default(now())

  @@unique([scope, nameNormalized, date, startTime])
  @@index([scope, nameNormalized])
  @@index([scope, date])
}
