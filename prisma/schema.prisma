// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  user
  partner
  moderator
  admin
}

enum UserStatus {
  active
  pending
  disabled
  locked
}

model User {
  id                  String     @id @default(cuid())
  name                String
  email               String     @unique
  emailVerified       Boolean    @default(false)
  image               String?
  password            String     @default("")
  role                UserRole   @default(user)
  status              UserStatus @default(active)
  emailVerifiedAt     DateTime?
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime   @default(now())
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  partnerOrganization String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  sessions            Session[]
  accounts            Account[]

  @@index([role])
  @@index([status])
  @@index([partnerOrganization])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model Page {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  content   Json      @default("[]")
  status    String    @default("draft")
  metaTitle String?
  metaDesc  String?
  ogImage   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  revisions PageRevision[]

  @@index([status])
  @@index([deletedAt])
  @@index([status, slug])
}

model PageRevision {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title     String
  content   Json     @default("[]")
  metaTitle String?
  metaDesc  String?
  ogImage   String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([pageId])
  @@index([createdAt])
}

model Activity {
  id           String   @id @default(cuid())
  user         String
  action       String // created, updated, deleted, published, unpublished, error
  resource     String // page, user, comment, setting
  resourceName String
  resourceId   String?
  details      String?
  createdAt    DateTime @default(now())
}

model File {
  id        String      @id @default(cuid())
  name      String
  type      String // "file" or "folder"
  fileType  String? // pdf, docx, xlsx, jpg, etc
  mimeType  String?
  size      Int? // bytes
  sha256    String?
  parentId  String?
  parent    File?       @relation("FileHierarchy", fields: [parentId], references: [id])
  children  File[]      @relation("FileHierarchy")
  isPrivate Boolean     @default(false)
  filePath  String? // relative path on disk
  createdBy String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  usage     FileUsage[]

  docTemplateSources    DocumentTemplate[]  @relation("DocTemplateSource")
  docGeneratedOutputs   GeneratedDocument[] @relation("DocGeneratedOutput")

  @@index([parentId])
  @@index([parentId, type])
  @@index([type])
  @@index([isPrivate])
  @@index([createdBy])
  @@index([sha256])
}

model FileUsage {
  id        String   @id @default(cuid())
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  pageId    String?
  pageSlug  String // slug de la page qui utilise le fichier
  context   String? // description du lieu d'utilisation
  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([pageId])
  @@index([pageSlug])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#7C3AED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ToolSection {
  id          String   @id @default(cuid())
  name        String   @unique // "Chômage", "Emploi", etc.
  description String?
  order       Int      @default(0)
  icon        String?
  tools       Tool[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tool {
  id          String      @id @default(cuid())
  sectionId   String
  section     ToolSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  name        String
  slug        String      @unique // "preavis", "agr", etc.
  description String
  type        String // "calc_preavis", "calc_agr", "locator", "doc_generator", etc.
  icon        String?
  popular     Boolean     @default(false)
  timeMin     Int?
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  documentTemplate DocumentTemplate?

  @@index([sectionId])
  @@index([slug])
}

model News {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @default("")
  excerpt     String
  category    String
  color       String    @default("#7C3AED")
  emoji       String    @default("📰")
  status      String    @default("draft")
  featured    Boolean   @default(false)
  image       String?
  readingTime Int?
  views       Int       @default(0)
  publishedAt DateTime?
  scheduledAt DateTime?
  createdBy   String
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishedAt])
  @@index([status, publishedAt(sort: Desc)])
  @@index([status, category])
  @@index([featured, status])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("active") // active, unsubscribed
  source    String   @default("actualites")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id         String   @id @default(cuid())
  name       String
  email      String
  subject    String
  message    String
  status     String   @default("NEW") // NEW, READ, REPLIED, ARCHIVED
  adminReply String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InboxEmail {
  id          String   @id @default(cuid())
  // IMAP UID — unique per mailbox + uidValidity. We use a composite key with mailbox.
  mailbox     String   @default("INBOX")
  uid         Int
  uidValidity String?
  // Headers
  messageId   String?
  inReplyTo   String?
  fromAddress String
  fromName    String?
  toAddresses String   @default("") // JSON array of addresses
  ccAddresses String   @default("") // JSON array of addresses
  subject     String   @default("")
  // Body (parsed)
  textBody    String   @default("")
  htmlBody    String?
  // Attachments metadata (we don't store file contents — just a list)
  attachments Json     @default("[]") // [{filename, contentType, size}]
  // Status
  isRead      Boolean  @default(false)
  isArchived  Boolean  @default(false)
  isReplied   Boolean  @default(false)
  // Timestamps
  receivedAt  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mailbox, uid])
  @@index([isRead])
  @@index([isArchived])
  @@index([receivedAt])
  @@index([fromAddress])
}

model BaremeFile {
  id             String   @id @default(cuid())
  name           String
  filePath       String
  effectiveDate  String
  uploadedAt     DateTime @default(now())
  description    String?
  fileType       String   @default("onem-rates")
  multiplicateur Float?
  status         String   @default("active")

  sheets    BareSheet[]
  createdBy String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([effectiveDate])
  @@index([status])
  @@index([fileType])
}

model BareSheet {
  id     String     @id @default(cuid())
  fileId String
  file   BaremeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String
  rowCount    Int
  colCount    Int     @default(0)

  // Données de la grille en JSON: [[cell1, cell2, ...], [cell1, ...], ...]
  cellData   String @default("[]")
  // Texte concaténé pour recherche full-text
  searchText String @default("")
  // Position dans le workbook
  sheetIndex Int    @default(0)

  createdAt DateTime @default(now())

  @@unique([fileId, name])
  @@index([fileId])
  @@index([category])
}

model DocumentTemplate {
  id                String   @id @default(cuid())
  toolId            String   @unique
  tool              Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  sourceFileId      String
  sourceFile        File     @relation("DocTemplateSource", fields: [sourceFileId], references: [id])
  sourceType        String // "pdf_acroform" | "pdf_flat" | "docx"
  schema            Json // DocumentField[] — voir lib/documents/types.ts
  outputFilenameTpl String   @default("document-{{date}}.pdf")
  rgpdNotice        String?
  retentionDays     Int      @default(30)
  status            String   @default("draft") // draft | published | archived
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  generated GeneratedDocument[]
  drafts    DocumentDraft[]
  revisions DocumentTemplateRevision[]

  @@index([status])
}

model DocumentTemplateRevision {
  id                String           @id @default(cuid())
  templateId        String
  template          DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version           Int
  schema            Json
  sourceType        String
  rgpdNotice        String?
  retentionDays     Int
  outputFilenameTpl String
  createdBy         String?
  createdAt         DateTime         @default(now())

  @@index([templateId])
  @@index([createdAt])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model GeneratedDocument {
  id           String           @id @default(cuid())
  templateId   String
  template     DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId       String?
  outputFileId String?
  outputFile   File?            @relation("DocGeneratedOutput", fields: [outputFileId], references: [id])
  payloadHash  String
  emailSentTo  String?
  ipHash       String?
  createdAt    DateTime         @default(now())
  expiresAt    DateTime

  @@index([templateId])
  @@index([expiresAt])
  @@index([userId])
}

model DocumentDraft {
  id         String           @id @default(cuid())
  templateId String
  template   DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId     String
  payload    Json
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([templateId, userId])
  @@index([userId])
}

model CommissionParitaire {
  id              String   @id @default(cuid())
  code            String   @unique
  numero          String
  numeroOfficiel  String
  codeOfficiel5   String
  suffixeInterne  String
  type            String
  nom             String
  label           String
  searchText      String
  updatedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([numeroOfficiel])
  @@index([code])
}

model PartnerDomain {
  id               String   @id @default(cuid())
  domain           String   @unique // ex: "cpas.brussels" (sans le @)
  organizationName String
  notes            String?
  isTest           Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
}

model U1Institution {
  id            String   @id @default(cuid())
  country       String   @unique
  countryCode   String?
  organization  String
  department    String?
  alternateName String?
  addressLines  Json     @default("[]")
  postalAddress String?
  phone         String?
  fax           String?
  website       String?
  emails        Json     @default("[]")
  extra         Json?
  updatedBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([country])
}
